# =============================================
# .env.template — Scouts & Guides de Cluses
# Copiez ce fichier en .env et remplissez les valeurs
# Ne commitez JAMAIS .env sur Git
# =============================================

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/scouts_cluses

# Session (longue chaîne aléatoire)
SESSION_SECRET=changez-moi-avec-une-chaine-aleatoire-longue

# Port (optionnel, 3000 par défaut)
PORT=3000

# Cloudinary (stockage fichiers et PDFs)
# Créer un compte sur https://cloudinary.com (plan gratuit : 25 Go)
# Récupérer les valeurs dans Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

