# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/scouts_cluses

# Session (longue chaîne aléatoire)
SESSION_SECRET=changez-moi-avec-une-chaine-aleatoire-longue

# Port (optionnel, 3000 par défaut)
PORT=3000

