<%# views/list.ejs — liste admin des inscrits par catégorie %>
<% var titrePage = titre + " — " + anneeScoute %>
<%- include('partials/_header') %>

<div class="container-fluid py-4">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h1 class="mb-0"><i class="bi bi-people me-2 text-success"></i><%= titre %> — <%= anneeScoute %></h1>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/admin/inscrits/scouts"    class="btn btn-sm btn-outline-secondary">Scouts</a>
      <a href="/admin/inscrits/guides"    class="btn btn-sm btn-outline-secondary">Guides</a>
      <a href="/admin/inscrits/louveteaux" class="btn btn-sm btn-outline-secondary">Louveteaux</a>
      <a href="/admin/logout"    class="btn btn-sm btn-danger">Déconnexion</a>
    </div>
  </div>

  <% if (inscriptions.length === 0) { %>
    <div class="step-card text-center py-5">
      <i class="bi bi-inbox" style="font-size:3rem; color:var(--border)"></i>
      <h5 class="mt-3 text-muted">Aucune inscription pour <%= anneeScoute %></h5>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-striped table-hover align-middle">
        <thead class="table-success">
          <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Naissance</th>
            <th>Âge</th>
            <th>Parent</th>
            <th>Email</th>
            <th>Tél.</th>
            <th>Contact urgence</th>
            <th>Droit image</th>
            <th>Transport</th>
            <th>Statut cotisation</th>
            <th>Documents</th>
          </tr>
        </thead>
        <tbody>
          <% inscriptions.forEach(i => { %>
            <tr>
              <td><strong><%= i.nom %></strong></td>
              <td><%= i.prenom %></td>
              <td><%= new Date(i.dateNaissance).toLocaleDateString('fr-FR') %></td>
              <td><%= i.age %></td>
              <td><%= i.parentNomPrenom %></td>
              <td><a href="mailto:<%= i.parentEmail %>"><%= i.parentEmail %></a></td>
              <td><a href="tel:<%= i.telPortable %>"><%= i.telPortable %></a></td>
              <td>
                <% if (i.contactUrgence) { %>
                  <%= i.contactUrgence.prenom %> <%= i.contactUrgence.nom %><br>
                  <small><a href="tel:<%= i.contactUrgence.telPortable %>"><%= i.contactUrgence.telPortable %></a></small>
                <% } else { %>—<% } %>
              </td>
              <td>
                <span class="badge <%= i.droitImage ? 'bg-success' : 'bg-danger' %>">
                  <%= i.droitImage ? 'Oui' : 'Non' %>
                </span>
              </td>
              <td>
                <span class="badge <%= i.autorisationTransport ? 'bg-success' : 'bg-danger' %>">
                  <%= i.autorisationTransport ? 'Oui' : 'Non' %>
                </span>
              </td>
              <td>
                <% if (i.cotisation) { %>
                  <span class="badge
                    <%= i.cotisation.statut === 'payee'      ? 'bg-success' :
                        i.cotisation.statut === 'echelonnee' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                    <%= i.cotisation.statut === 'payee'      ? 'Payée' :
                        i.cotisation.statut === 'echelonnee' ? 'Échelonnée' : 'En attente' %>
                  </span>
                  <small class="d-block text-muted"><%= i.cotisation.montant %>€</small>
                <% } else { %>—<% } %>
              </td>
              <td>
                <div class="d-flex flex-column gap-1">
                  <% if (i.pdfPath) { %>
                    <a href="<%= i.pdfPath %>" target="_blank" class="btn btn-xs btn-outline-success py-0 px-2">
                      <i class="bi bi-file-pdf me-1"></i>Autorisation
                    </a>
                  <% } %>
                  <% if (i.sanitaryPdfPath) { %>
                    <a href="<%= i.sanitaryPdfPath %>" target="_blank" class="btn btn-xs btn-outline-secondary py-0 px-2">
                      <i class="bi bi-file-medical me-1"></i>Fiche santé
                    </a>
                  <% } %>
                  <% if (i.vaccinScan) { %>
                    <a href="/uploads/<%= i.vaccinScan %>" target="_blank" class="btn btn-xs btn-outline-info py-0 px-2">
                      <i class="bi bi-paperclip me-1"></i>Vaccins
                    </a>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p class="text-muted small mt-2"><%= inscriptions.length %> inscription(s)</p>
  <% } %>
</div>

<%- include('partials/_footer') %>
