<%# views/inscription-annuelle.ejs %>
<% titre = "Inscription " + enfant.prenom %>
<%- include('partials/_header', { extraHead: '<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>' }) %>

<div class="container py-5">
  <div class="step-card">

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
      <h2 class="mb-0">
        <i class="bi bi-pencil-square me-2 text-success"></i>
        <%= typeInscription === 'camp' ? 'Inscription Camp' : 'Inscription Année' %>
        — <%= enfant.prenom %>
      </h2>
      <span class="badge fs-6 <%= typeInscription === 'camp' ? 'bg-warning text-dark' : 'bg-success' %>">
        <%= anneeScoute %>
      </span>
      <% if (estModification) { %>
        <span class="badge bg-danger fs-6">Correction demandée</span>
      <% } %>
    </div>

    <% if (inscriptionExistante?.commentaireAdmin) { %>
      <div class="alert-custom alert-danger-custom mb-4">
        <h6><i class="bi bi-chat-dots me-2"></i>Commentaire de l'administrateur :</h6>
        <p class="mb-0"><%= inscriptionExistante.commentaireAdmin %></p>
      </div>
    <% } %>

    <%# Statut mineur/majeur %>
    <div class="p-3 mb-4 rounded-3 <%= estMajeur ? 'bg-primary bg-opacity-10' : 'bg-success bg-opacity-10' %>" style="border-left:4px solid <%= estMajeur ? '#0d6efd' : 'var(--success)' %>">
      <i class="bi bi-person-check me-2"></i>
      <strong><%= enfant.prenom %></strong> est
      <strong><%= estMajeur ? 'majeur(e)' : 'mineur(e)' %></strong>
      (<%= ageAuRemplissage %> ans à la date de ce formulaire).
      <% if (!estMajeur) { %><small class="text-muted ms-2">Les autorisations parentales s'appliquent.</small><% } %>
    </div>

    <%# Récapitulatif %>
    <div class="p-4 mb-4 rounded-3" style="background:#f8fffe; border:1px solid var(--border);">
      <h5 class="text-success mb-3"><i class="bi bi-info-circle me-2"></i>Récapitulatif</h5>
      <div class="row g-2">
        <div class="col-md-6"><strong>Enfant :</strong> <%= enfant.prenom %> <%= enfant.nom %></div>
        <div class="col-md-6"><strong>Catégorie :</strong> <span class="badge bg-success text-capitalize"><%= enfant.categorie %></span></div>
        <div class="col-md-6"><strong>Parent :</strong> <%= parent.prenom %> <%= parent.nom %></div>
        <div class="col-md-6"><strong>Tél. :</strong> <%= parent.telPortable %></div>
      </div>
      <div class="mt-2">
        <a href="/modifier-enfant/<%= enfant._id %>" class="btn btn-sm btn-outline-secondary me-2">
          <i class="bi bi-pencil me-1"></i>Modifier le profil enfant
        </a>
        <a href="/profil" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-pencil me-1"></i>Modifier mon profil
        </a>
      </div>
    </div>

    <form id="inscriptionForm" novalidate>
      <input type="hidden" name="typeInscription" value="<%= typeInscription %>">
      <input type="hidden" name="anneeScoute"     value="<%= anneeScoute %>">

      <%# ---- AUTORISATIONS ---- %>
      <h5 class="text-success mb-3"><i class="bi bi-check2-square me-2"></i>Autorisations</h5>
      <div class="p-4 bg-light rounded-3 mb-4">
        <div class="form-check mb-2">
          <input class="form-check-input" type="checkbox" id="droitImage" name="droitImage" checked>
          <label class="form-check-label" for="droitImage">J'autorise le droit à l'image et la diffusion</label>
        </div>
        <div class="form-check mb-2">
          <input class="form-check-input" type="checkbox" id="autorisationTransport" name="autorisationTransport" checked>
          <label class="form-check-label" for="autorisationTransport">J'autorise le transport en véhicule bénévole</label>
        </div>
        <% if (!estMajeur) { %>
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="autorisationHospitalisation" name="autorisationHospitalisation" checked>
            <label class="form-check-label" for="autorisationHospitalisation">
              J'autorise le personnel encadrant à prendre toute mesure d'urgence médicale ou d'hospitalisation si nécessaire
            </label>
          </div>
        <% } %>
      </div>

      <%# ---- AUTORISATION ACTIVITÉS AUTONOMES (mineurs uniquement) ---- %>
      <% if (!estMajeur) { %>
        <h5 class="text-success mb-3 mt-4"><i class="bi bi-signpost-split me-2"></i>Autorisation activités autonomes</h5>
        <div class="p-4 rounded-3 mb-4" style="background:#f0faf0; border:2px solid var(--border);">
          <p class="small mb-3" style="text-align:justify;">
            Certaines activités occasionnelles en autonomie peuvent être organisées pour accompagner
            les jeunes vers une responsabilité progressive. Les modalités de ces activités sont fixées
            en mesurant leur capacité d'autonomie individuelle et collective. Les jeunes concernés
            participent à leur préparation avec l'équipe d'encadrement : repérage des lieux, mise à
            disposition de moyens adaptés et de moyens de communication (téléphones portables).
            L'équipe d'encadrement se tient à proximité pour intervenir en cas de besoin.
          </p>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="autorisationActivitesAutonomes"
                   name="autorisationActivitesAutonomes" onchange="toggleSignatureAutonomes(this)">
            <label class="form-check-label fw-bold" for="autorisationActivitesAutonomes">
              J'autorise mon enfant à participer aux activités autonomes dans les conditions décrites ci-dessus
            </label>
          </div>

          <div id="signatureAutonomesSection" class="d-none">
            <p class="fw-bold mb-2">Bon pour accord — Signature du responsable légal :</p>
            <div class="signature-container">
              <canvas id="signaturePadAutonomes" class="signature-pad"></canvas>
              <div class="mt-3 d-flex gap-3 justify-content-center">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="clearSignatureAutonomes">
                  <i class="bi bi-eraser me-1"></i>Effacer
                </button>
              </div>
              <div id="signatureAutonomesError" class="text-danger small mt-2 d-none">
                <i class="bi bi-exclamation-circle me-1"></i>La signature est obligatoire si vous accordez cette autorisation.
              </div>
            </div>
            <input type="hidden" id="signatureActivitesAutonomes" name="signatureActivitesAutonomes">
          </div>
        </div>
      <% } %>

      <%# ---- PERMIS DE CONDUIRE (majeurs uniquement) ---- %>
      <% if (estMajeur) { %>
        <h5 class="text-success mb-3"><i class="bi bi-car-front me-2"></i>Permis de conduire</h5>
        <div class="p-4 bg-light rounded-3 mb-4">
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="permisConduire" name="permisConduire"
                   onchange="togglePermis(this)">
            <label class="form-check-label fw-bold" for="permisConduire">Je possède un permis de conduire</label>
          </div>
          <div id="permisDetails" class="d-none">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Catégories</label>
                <div class="d-flex gap-3 flex-wrap">
                  <% ['B', 'BE', 'D', 'DE'].forEach(cat => { %>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="permisCategories" value="<%= cat %>" id="permis<%= cat %>">
                      <label class="form-check-label" for="permis<%= cat %>"><%= cat %></label>
                    </div>
                  <% }) %>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-floating-custom">
                  <input type="text" class="form-control" id="permisNumero" name="permisNumero" placeholder="N°">
                  <label for="permisNumero">Numéro de permis</label>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <%# ---- LIEU ---- %>
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <div class="form-floating-custom">
            <input type="text" class="form-control" id="lieuInscription" name="lieuInscription" value="Cluses">
            <label for="lieuInscription">Lieu de signature</label>
          </div>
        </div>
      </div>

      <%# ---- SIGNATURE ---- %>
      <h5 class="text-success mb-3"><i class="bi bi-vector-pen me-2"></i>Signature</h5>
      <p class="text-muted small mb-3">Valeur légale conformément à la réglementation eIDAS.</p>
      <div class="signature-container">
        <label class="form-label fw-bold mb-2">Signez ici</label>
        <canvas id="signaturePad" class="signature-pad"></canvas>
        <div class="mt-3 d-flex gap-3 justify-content-center">
          <button type="button" class="btn btn-outline-secondary" id="clearSignature">
            <i class="bi bi-eraser me-1"></i>Effacer
          </button>
        </div>
        <div id="signatureError" class="text-danger small mt-2 d-none">
          <i class="bi bi-exclamation-circle me-1"></i>La signature est obligatoire pour soumettre.
        </div>
      </div>
      <input type="hidden" id="signatureDroitImage" name="signatureDroitImage">
      <input type="hidden" id="signatureSanitaire"  name="signatureSanitaire">

      <%# ---- COTISATION ---- %>
      <h5 class="text-success mt-4 mb-3"><i class="bi bi-cash me-2"></i>Cotisation</h5>
      <div class="p-4 bg-light rounded-3 mb-4">
        <div class="row g-3 align-items-center">
          <div class="col-md-4">
            <div class="form-floating-custom">
              <input type="number" class="form-control" id="montantCotisation" name="montantCotisation"
                     value="<%= typeInscription === 'camp' ? config.cotisationCamp : config.cotisationAnnee %>"
                     min="0" step="0.01">
              <label for="montantCotisation">Montant (€)</label>
            </div>
          </div>
          <div class="col-md-4">
            <div class="form-floating-custom">
              <select class="form-select" id="modePaiement" name="modePaiement">
                <option value="">Non précisé</option>
                <option value="cheque">Chèque</option>
                <option value="especes">Espèces</option>
                <option value="virement">Virement</option>
                <option value="helloasso">HelloAsso</option>
              </select>
              <label for="modePaiement">Mode de paiement</label>
            </div>
          </div>
          <div class="col-12">
            <div class="p-3 rounded-3" style="background:#fff3cd; border-left:4px solid #ffc107;">
              <strong>Virement :</strong> FR76 1680 7000 3085 8868 0119 504<br>
              <strong>Référence :</strong> Cotisation <%= enfant.prenom %> <%= enfant.nom %> — <%= anneeScoute %>
            </div>
          </div>
        </div>
      </div>

      <div class="form-check mb-4">
        <input class="form-check-input" type="checkbox" id="acceptRGPD" required>
        <label class="form-check-label" for="acceptRGPD">
          J'accepte la <a href="/mentions-legales" target="_blank">politique de confidentialité</a> *
        </label>
      </div>

      <%# Boutons : Brouillon + Soumettre %>
      <div class="d-flex gap-3 flex-wrap">
        <button type="button" class="btn btn-outline-secondary btn-custom" id="brouillonBtn">
          <i class="bi bi-floppy me-2"></i>Enregistrer en brouillon
        </button>
        <button type="submit" class="btn btn-primary-custom btn-custom flex-fill" id="submitBtn">
          <i class="bi bi-send me-2"></i>Soumettre pour validation
        </button>
      </div>
      <p class="text-muted small mt-2">
        <i class="bi bi-info-circle me-1"></i>
        Le brouillon ne nécessite pas de signature. Vous pourrez le compléter plus tard.
      </p>

    </form>
  </div>
</div>

<%- include('partials/_footer') %>

<script>
  // ---- Canvas signature ----
  const canvas = document.getElementById('signaturePad');
  const pad    = new SignaturePad(canvas, { penColor: '#000' });

  function resizeCanvas() {
    const ratio = Math.max(window.devicePixelRatio || 1, 1);
    const data  = pad.toData();
    canvas.width  = canvas.offsetWidth  * ratio;
    canvas.height = canvas.offsetHeight * ratio;
    canvas.getContext('2d').scale(ratio, ratio);
    pad.clear();
    pad.fromData(data);
  }
  window.addEventListener('resize', resizeCanvas);
  document.addEventListener('DOMContentLoaded', resizeCanvas);
  document.getElementById('clearSignature').addEventListener('click', () => pad.clear());

  // ---- Permis ----
  function togglePermis(cb) {
    document.getElementById('permisDetails').classList.toggle('d-none', !cb.checked);
  }

  // ---- Collecte des données du formulaire ----
  function collectPayload(action) {
    const sig = pad.isEmpty() ? null : pad.toDataURL();
    if (sig) {
      document.getElementById('signatureDroitImage').value = sig;
      document.getElementById('signatureSanitaire').value  = sig;
    }
    const form    = document.getElementById('inscriptionForm');
    const payload = {
      action,
      typeInscription: form.typeInscription.value,
      anneeScoute:     form.anneeScoute.value,
      droitImage:            document.getElementById('droitImage')?.checked            ? 'on' : '',
      autorisationTransport: document.getElementById('autorisationTransport')?.checked ? 'on' : '',
      autorisationHospitalisation: document.getElementById('autorisationHospitalisation')?.checked ? 'on' : '',
      autorisationActivitesAutonomes: document.getElementById('autorisationActivitesAutonomes')?.checked ? 'on' : '',
      signatureActivitesAutonomes: document.getElementById('signatureActivitesAutonomes')?.value || null,
      lieuInscription:       document.getElementById('lieuInscription').value,
      signatureDroitImage:   sig,
      signatureSanitaire:    sig,
      montantCotisation:     document.getElementById('montantCotisation').value,
      modePaiement:          document.getElementById('modePaiement').value,
    };
    // Permis
    const permisCb = document.getElementById('permisConduire');
    if (permisCb?.checked) {
      payload.permisConduire = 'on';
      payload.permisNumero   = document.getElementById('permisNumero')?.value || '';
      payload.permisCategories = [...document.querySelectorAll('input[name="permisCategories"]:checked')]
        .map(cb => cb.value);
    }
    return payload;
  }

  // ---- Soumission ----
  document.getElementById('inscriptionForm').addEventListener('submit', async e => {
    e.preventDefault();
    if (pad.isEmpty()) {
      document.getElementById('signatureError').classList.remove('d-none');
      canvas.scrollIntoView({ behavior: 'smooth' });
      return;
    }
    // Validation signature autonomes si coché
    const autCb  = document.getElementById('autorisationActivitesAutonomes');
    if (autCb?.checked && padAut?.isEmpty()) {
      document.getElementById('signatureAutonomesError').classList.remove('d-none');
      canvasAut.scrollIntoView({ behavior: 'smooth' });
      return;
    }
    if (autCb?.checked && padAut && !padAut.isEmpty()) {
      document.getElementById('signatureActivitesAutonomes').value = padAut.toDataURL();
    }
    document.getElementById('signatureError').classList.add('d-none');
    await envoyer('soumettre');
  });

  // ---- Brouillon ----
  document.getElementById('brouillonBtn').addEventListener('click', () => envoyer('brouillon'));

  // ---- Signature Pad Activités Autonomes ----
  const canvasAut = document.getElementById('signaturePadAutonomes');
  let padAut = null;
  if (canvasAut) {
    padAut = new SignaturePad(canvasAut, { penColor: '#000' });
    function resizeCanvasAut() {
      const ratio = Math.max(window.devicePixelRatio || 1, 1);
      const data  = padAut.toData();
      canvasAut.width  = canvasAut.offsetWidth  * ratio;
      canvasAut.height = canvasAut.offsetHeight * ratio;
      canvasAut.getContext('2d').scale(ratio, ratio);
      padAut.clear();
      padAut.fromData(data);
    }
    window.addEventListener('resize', resizeCanvasAut);
    setTimeout(resizeCanvasAut, 100);
    document.getElementById('clearSignatureAutonomes').addEventListener('click', () => padAut.clear());
  }

  function toggleSignatureAutonomes(cb) {
    const section = document.getElementById('signatureAutonomesSection');
    section.classList.toggle('d-none', !cb.checked);
    if (cb.checked) setTimeout(() => { if (padAut) { const r = Math.max(window.devicePixelRatio||1,1); canvasAut.width = canvasAut.offsetWidth*r; canvasAut.height = canvasAut.offsetHeight*r; canvasAut.getContext('2d').scale(r,r); padAut.clear(); } }, 50);
  }

  async function envoyer(action) {
    const btn = action === 'brouillon'
      ? document.getElementById('brouillonBtn')
      : document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Enregistrement...';

    try {
      const res  = await fetch('/inscrire-enfant/<%= enfant._id %>', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(collectPayload(action))
      });
      const data = await res.json();

      if (res.ok && data.success) {
        if (action === 'brouillon') {
          alert('Brouillon enregistré ! Vous pouvez y revenir depuis votre espace.');
          window.location.href = '/espace-parent';
        } else {
          document.body.innerHTML = `
            <div class="container text-center py-5">
              <div class="step-card mx-auto" style="max-width:600px">
                <i class="bi bi-hourglass-split text-warning" style="font-size:4rem"></i>
                <h2 class="mt-3">${data.message}</h2>
                <p class="text-muted">L'administrateur validera votre inscription prochainement.</p>
                <div class="d-flex gap-3 justify-content-center mt-4 flex-wrap">
                  ${data.pdfUrl ? `<a href="${data.pdfUrl}" target="_blank" class="btn btn-outline-success"><i class="bi bi-file-pdf me-1"></i>Autorisation</a>` : ''}
                  ${data.sanitaryPdfUrl ? `<a href="${data.sanitaryPdfUrl}" target="_blank" class="btn btn-outline-secondary"><i class="bi bi-file-medical me-1"></i>Fiche sanitaire</a>` : ''}
                  <a href="/espace-parent" class="btn btn-primary-custom btn-custom"><i class="bi bi-house me-1"></i>Mon espace</a>
                </div>
              </div>
            </div>`;
        }
      } else {
        alert(data.message || 'Une erreur est survenue.');
        btn.disabled = false;
        btn.innerHTML = action === 'brouillon'
          ? '<i class="bi bi-floppy me-2"></i>Enregistrer en brouillon'
          : '<i class="bi bi-send me-2"></i>Soumettre pour validation';
      }
    } catch {
      alert('Erreur réseau.');
      btn.disabled = false;
    }
  }
</script>
