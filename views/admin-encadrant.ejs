<%# views/admin-encadrant.ejs — détail d'un encadrant %>
<% titre = "Encadrant — " + encadrant.prenom + " " + encadrant.nom %>
<%- include('partials/_header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="step-card">
        <div class="d-flex justify-content-between align-items-start mb-4">
          <div>
            <h2 class="mb-1"><i class="bi bi-person-badge me-2 text-success"></i><%= encadrant.prenom %> <%= encadrant.nom %></h2>
            <p class="text-muted mb-0"><%= encadrant.email %> — <%= encadrant.telPortable %></p>
          </div>
          <span class="badge fs-6
            <%= encadrant.encadrant?.statut === 'valide'    ? 'bg-success' :
                encadrant.encadrant?.statut === 'refuse'    ? 'bg-danger'  : 'bg-warning text-dark' %>">
            <%= encadrant.encadrant?.statut === 'valide'    ? 'Validé' :
                encadrant.encadrant?.statut === 'refuse'    ? 'Refusé' : 'En attente' %>
          </span>
        </div>

        <h5 class="text-success mb-2">Catégories encadrées</h5>
        <div class="mb-4">
          <% (encadrant.encadrant?.categories || []).forEach(cat => { %>
            <span class="badge bg-success text-capitalize me-2 fs-6"><%= cat %></span>
          <% }) %>
          <% if (!encadrant.encadrant?.categories?.length) { %>
            <span class="text-muted">Non précisé</span>
          <% } %>
        </div>

        <h5 class="text-success mb-2">Documents</h5>
        <div class="d-flex gap-2 flex-wrap mb-4">
          <% if (encadrant.encadrant?.bafaScan) { %>
            <a href="/uploads/<%= encadrant.encadrant.bafaScan %>" target="_blank" class="btn btn-outline-info">
              <i class="bi bi-file-earmark me-1"></i>BAFA / Diplôme
            </a>
          <% } else { %>
            <span class="badge bg-secondary p-2">BAFA non fourni</span>
          <% } %>
          <% if (encadrant.encadrant?.casierJudiciaire) { %>
            <a href="/uploads/<%= encadrant.encadrant.casierJudiciaire %>" target="_blank" class="btn btn-outline-info">
              <i class="bi bi-file-earmark me-1"></i>Casier judiciaire
            </a>
          <% } else { %>
            <span class="badge bg-secondary p-2">Casier non fourni</span>
          <% } %>
          <% (encadrant.encadrant?.autresDocuments || []).forEach((doc, i) => { %>
            <a href="/uploads/<%= doc %>" target="_blank" class="btn btn-outline-secondary">
              <i class="bi bi-paperclip me-1"></i>Autre doc <%= i + 1 %>
            </a>
          <% }) %>
        </div>

        <% if (encadrant.encadrant?.noteAdmin) { %>
          <div class="p-3 rounded-3 mb-4" style="background:#f8f9fa;">
            <strong>Note admin :</strong> <%= encadrant.encadrant.noteAdmin %>
          </div>
        <% } %>

        <%# Actions %>
        <% if (encadrant.encadrant?.statut !== 'valide') { %>
          <button class="btn btn-success me-2" onclick="changerStatut('<%= encadrant._id %>','valide')">
            <i class="bi bi-check-circle me-1"></i>Valider
          </button>
        <% } %>
        <% if (encadrant.encadrant?.statut !== 'refuse') { %>
          <button class="btn btn-danger me-2" onclick="changerStatut('<%= encadrant._id %>','refuse')">
            <i class="bi bi-x-circle me-1"></i>Refuser
          </button>
        <% } %>
        <a href="/admin" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/_footer') %>

<script>
  async function changerStatut(id, statut) {
    const note = statut === 'refuse' ? (prompt('Motif du refus (optionnel) :') || '') : '';
    const res  = await fetch(`/admin/encadrant/${id}/statut`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ statut, noteAdmin: note })
    });
    const data = await res.json();
    if (data.success) window.location.href = '/admin';
    else alert('Erreur : ' + data.message);
  }
</script>
