<%# views/inscription-confirmee.ejs %>
<% titre = "Inscription confirmée — " + enfant.prenom %>
<%- include('partials/_header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="step-card text-center">

        <i class="bi bi-check-circle-fill text-success" style="font-size:4rem"></i>
        <h2 class="mt-3"><%= enfant.prenom %> est inscrit(e) !</h2>
        <p class="text-muted">Année scoute <strong><%= inscription.anneeScoute %></strong> —
          <span class="badge bg-success text-capitalize"><%= inscription.categorie %></span>
        </p>

        <div class="p-3 rounded-3 mb-4 text-start" style="background:#f8fffe; border:1px solid var(--border);">
          <div class="row g-2">
            <div class="col-6"><strong>Enfant :</strong> <%= enfant.prenom %> <%= enfant.nom %></div>
            <div class="col-6"><strong>Parent :</strong> <%= parent.prenom %> <%= parent.nom %></div>
            <div class="col-6">
              <strong>Statut :</strong>
              <span class="badge
                <%= inscription.statut === 'validee'  ? 'bg-success' :
                    inscription.statut === 'soumise'  ? 'bg-primary' : 'bg-warning text-dark' %>">
                <%= inscription.statut === 'validee'  ? 'Validée' :
                    inscription.statut === 'soumise'  ? 'En attente de validation' : 'Brouillon' %>
              </span>
            </div>
            <div class="col-6">
              <strong>Cotisation :</strong>
              <% if (inscription.cotisation) { %>
                <%= inscription.cotisation.montant %>€ —
                <span class="badge
                  <%= inscription.cotisation.statut === 'payee' ? 'bg-success' : 'bg-secondary' %>">
                  <%= inscription.cotisation.statut === 'payee' ? 'Payée' : 'En attente' %>
                </span>
              <% } %>
            </div>
          </div>
        </div>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <% if (inscription.pdfPath) { %>
            <a href="<%= inscription.pdfPath %>" target="_blank" class="btn btn-outline-success">
              <i class="bi bi-file-pdf me-1"></i>Autorisation
            </a>
          <% } %>
          <% if (inscription.sanitaryPdfPath) { %>
            <a href="<%= inscription.sanitaryPdfPath %>" target="_blank" class="btn btn-outline-secondary">
              <i class="bi bi-file-medical me-1"></i>Fiche sanitaire
            </a>
          <% } %>
          <a href="/espace-parent" class="btn btn-primary-custom btn-custom">
            <i class="bi bi-house me-1"></i>Mon espace
          </a>
        </div>

      </div>
    </div>
  </div>
</div>

<%- include('partials/_footer') %>
