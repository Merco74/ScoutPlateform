<%# views/espace-encadrant.ejs %>
<% titre = "Espace encadrant" %>
<%- include('partials/_header') %>

<div class="container py-5">

  <div class="hero mb-5">
    <h1><i class="bi bi-shield-check me-2"></i>Espace encadrant</h1>
    <p>Bonjour <strong><%= encadrant.prenom %> <%= encadrant.nom %></strong> — Année scoute : <strong><%= anneeScoute %></strong></p>
  </div>

  <%# Statut de validation %>
  <% if (statut === 'en_attente') { %>
    <div class="alert-custom mb-5 p-4" style="background:#fff3cd; border-left:5px solid #ffc107;">
      <h5><i class="bi bi-hourglass-split me-2"></i>Validation en attente</h5>
      <p class="mb-0">Vos documents sont en cours d'examen par l'administrateur. Vous pourrez consulter les listes une fois votre compte validé.</p>
    </div>
  <% } else if (statut === 'refuse') { %>
    <div class="alert-custom alert-danger-custom mb-5">
      <h5><i class="bi bi-x-circle me-2"></i>Demande refusée</h5>
      <p class="mb-0">Votre demande d'accès encadrant a été refusée. Contactez l'administrateur pour plus d'informations.</p>
    </div>
  <% } else { %>

    <%# Listes des inscrits par catégorie %>
    <% const categories = Object.keys(inscritsParCategorie); %>
    <% if (categories.length === 0) { %>
      <div class="step-card text-center py-5">
        <i class="bi bi-inbox" style="font-size:3rem; color:var(--border)"></i>
        <h5 class="mt-3 text-muted">Aucune catégorie assignée</h5>
        <p class="text-muted">Contactez l'administrateur pour vous assigner des catégories.</p>
      </div>
    <% } else { %>
      <% categories.forEach(cat => { %>
        <div class="mb-5">
          <h3 class="text-success mb-3 text-capitalize">
            <i class="bi bi-people me-2"></i><%= cat %>s
            <span class="badge bg-success ms-2"><%= inscritsParCategorie[cat].length %></span>
          </h3>

          <% if (inscritsParCategorie[cat].length === 0) { %>
            <div class="step-card text-center py-4">
              <p class="text-muted mb-0">Aucun inscrit pour cette catégorie.</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-striped table-hover align-middle">
                <thead class="table-success">
                  <tr>
                    <th>Enfant</th>
                    <th>Âge</th>
                    <th>Parent</th>
                    <th>Tél.</th>
                    <th>Contact urgence</th>
                    <th>Allergies</th>
                    <th>Documents</th>
                  </tr>
                </thead>
                <tbody>
                  <% inscritsParCategorie[cat].forEach(i => { %>
                    <tr>
                      <td><strong><%= i.prenom %> <%= i.nom %></strong></td>
                      <td><%= i.age %> ans</td>
                      <td><%= i.parentNomPrenom %></td>
                      <td><a href="tel:<%= i.telPortable %>"><%= i.telPortable %></a></td>
                      <td>
                        <% if (i.contactUrgence) { %>
                          <%= i.contactUrgence.prenom %> <%= i.contactUrgence.nom %><br>
                          <small><a href="tel:<%= i.contactUrgence.telPortable %>"><%= i.contactUrgence.telPortable %></a></small>
                        <% } else { %>—<% } %>
                      </td>
                      <td>
                        <% if (i.allergiesAlimentaires || i.allergiesMedicament || i.allergiesAutres) { %>
                          <span class="badge bg-warning text-dark">
                            <i class="bi bi-exclamation-triangle me-1"></i>Oui
                          </span>
                          <% if (i.allergiesDetails) { %>
                            <br><small class="text-muted"><%= i.allergiesDetails %></small>
                          <% } %>
                        <% } else { %>
                          <span class="badge bg-success">Non</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (i.pdfPath) { %>
                          <a href="<%= i.pdfPath %>" target="_blank" class="btn btn-xs btn-outline-success py-0 px-2">
                            <i class="bi bi-file-pdf me-1"></i>Autorisation
                          </a>
                        <% } %>
                        <% if (i.sanitaryPdfPath) { %>
                          <a href="<%= i.sanitaryPdfPath %>" target="_blank" class="btn btn-xs btn-outline-secondary py-0 px-2 mt-1">
                            <i class="bi bi-file-medical me-1"></i>Fiche santé
                          </a>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      <% }) %>
    <% } %>
  <% } %>

  <%# Lien vers espace parent si double rôle %>
  <% if (roles.includes('parent')) { %>
    <div class="step-card mt-4">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-1"><i class="bi bi-house me-2 text-success"></i>Espace parent</h5>
          <p class="text-muted mb-0">Gérer vos enfants et leurs inscriptions</p>
        </div>
        <a href="/espace-parent" class="btn btn-outline-secondary">Accéder</a>
      </div>
    </div>
  <% } %>

</div>

<%- include('partials/_footer') %>
